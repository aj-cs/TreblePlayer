<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="TreblePlayer.Avalonia.Views.MainView">

    <Grid RowDefinitions="*, 85">
        
        <Grid Grid.Row="0" ColumnDefinitions="240, *, 360" Margin="10">
            
            <suki:GlassCard Grid.Column="0" Margin="5" Padding="15">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Text="TreblePlayer" Margin="10,10,10,25" FontSize="20" FontWeight="Bold"/>
                    
                    <StackPanel Grid.Row="1" Spacing="8">
                        <Button Classes="Flat" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Home"/>
                        <Button Classes="Flat" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Albums"/>
                        <Button Classes="Flat" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Songs"/>
                        <Button Classes="Flat" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Playlists"/>
                        <Button Classes="Flat" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Insights"/>
                        <Button Classes="Flat" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Settings" Margin="0,20,0,0"/>
                    </StackPanel>
                </Grid>
            </suki:GlassCard>

            <Grid Grid.Column="1" RowDefinitions="Auto, *" Margin="10,5">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="5,0,5,15">
                    <TextBox Grid.Column="0" PlaceholderText="Search tracks, artists, albums..." Width="320" HorizontalAlignment="Left"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="Per row:" VerticalAlignment="Center"/>
                        <Slider x:Name="GridSlider" Minimum="3" Maximum="8" Value="5" Width="120" SmallChange="1" LargeChange="1"/>
                        <TextBlock Text="{Binding #GridSlider.Value, StringFormat=\{0:0\}}" VerticalAlignment="Center" Width="15"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <suki:GlassCard Padding="10">
                        <UniformGrid Columns="{Binding #GridSlider.Value}" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                            
                            <Button Classes="Flat" Margin="8" HorizontalAlignment="Stretch" Padding="0"
                                    Height="{Binding $self.Bounds.Width}">
                                <Grid>
                                    <Border CornerRadius="8" ClipToBounds="True" Background="#2A3545">
                                        <Panel Background="{DynamicResource SukiPrimaryColor}" Opacity="0.15"/>
                                    </Border>
                                    
                                    <Grid RowDefinitions="*, Auto" Margin="12">
                                        <TextBlock Grid.Row="0" Text="💿" FontSize="28" Opacity="0.4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="1" Spacing="2">
                                            <TextBlock Text="Refraction" FontSize="13" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="Synthsphere" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Button>

                            <Button Classes="Flat" Margin="8" HorizontalAlignment="Stretch" Padding="0"
                                    Height="{Binding $self.Bounds.Width}">
                                <Grid>
                                    <Border CornerRadius="8" ClipToBounds="True" Background="#2A3545">
                                        <Panel Background="{DynamicResource SukiPrimaryColor}" Opacity="0.15"/>
                                    </Border>
                                    <Grid RowDefinitions="*, Auto" Margin="12">
                                        <TextBlock Grid.Row="0" Text="💿" FontSize="28" Opacity="0.4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="1" Spacing="2">
                                            <TextBlock Text="Circuit Bound" FontSize="13" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="Binary Pulse" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Button>

                        </UniformGrid>
                    </suki:GlassCard>
                </ScrollViewer>
            </Grid>

            <suki:GlassCard Grid.Column="2" Margin="5" Padding="10">
                <TabControl>
                    
                    <TabItem Header="Album Player">
                        <Grid RowDefinitions="Auto, *">
                            <StackPanel Grid.Row="0" Margin="5,15,5,10" Spacing="15">
                                <Grid ColumnDefinitions="100, *">
                                    <Border Grid.Column="0" Width="100" Height="100" CornerRadius="8" ClipToBounds="True" Background="#2A3545">
                                        <Panel Background="{DynamicResource SukiPrimaryColor}" Opacity="0.2"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="Refraction" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Synthsphere" FontSize="14" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="2026 — 4 Tracks" FontSize="11" Opacity="0.5"/>
                                    </StackPanel>
                                </Grid>
                                <Separator Height="1" Background="{DynamicResource SukiBorderBrush}"/>
                            </StackPanel>
                            
                            <ScrollViewer Grid.Row="1" Margin="5,0">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="1. Introductory Track" Padding="5,3"/>
                                    <TextBlock Text="2. Deep Workspace Resonance" Padding="5,3"/>
                                    <TextBlock Text="3. Core Logic Array" Padding="5,3"/>
                                    <TextBlock Text="4. Terminal Velocity" Padding="5,3"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Queue">
                        <Grid RowDefinitions="Auto, *">
                            <TextBlock Grid.Row="0" Text="3 Items in Queue" Margin="5,10" Opacity="0.5" FontSize="11"/>
                            <ScrollViewer Grid.Row="1">
                                <StackPanel Spacing="6" Margin="5">
                                    <Border Background="{DynamicResource SukiBackground}" Padding="10" CornerRadius="6">
                                        <TextBlock Text="Now Playing: Introductory Track" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="{DynamicResource SukiCardBackground}" Padding="10" CornerRadius="6">
                                        <TextBlock Text="Up Next: Deep Workspace Resonance"/>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                    
                </TabControl>
            </suki:GlassCard>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource SukiCardBackground}" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid ColumnDefinitions="280, *, 240">
                
                <Grid Grid.Column="0" ColumnDefinitions="Auto, *" VerticalAlignment="Center">
                    <Border Grid.Column="0" Width="45" Height="45" CornerRadius="6" Background="#2A3545" ClipToBounds="True">
                        <Panel Background="{DynamicResource SukiPrimaryColor}" Opacity="0.2"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Introductory Track" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Synthsphere" FontSize="12" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="Auto, Auto" VerticalAlignment="Center" Margin="20,0">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,0,0,4">
                        <Button Content="🔀" Classes="Flat" FontSize="12" Opacity="0.7"/>
                        <Button Content="⏮" Classes="Flat" FontSize="14"/>
                        <Button Content="▶" Background="{DynamicResource SukiBackground}" Width="36" Height="36" CornerRadius="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        <Button Content="⏭" Classes="Flat" FontSize="14"/>
                        <Button Content="🔁" Classes="Flat" FontSize="12" Opacity="0.7"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="0:21" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="21" Margin="12,0" Height="24" Theme="{DynamicResource SukiSliderTheme}"/>
                        <TextBlock Grid.Column="2" Text="4:15" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="🔊" VerticalAlignment="Center" Opacity="0.7"/>
                    <Slider Minimum="0" Maximum="100" Value="75" Width="100" VerticalAlignment="Center" Theme="{DynamicResource SukiSliderTheme}"/>
                </StackPanel>
                
            </Grid>
        </Border>
    </Grid>
</UserControl>