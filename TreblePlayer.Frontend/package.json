{
  "name": "trebleplayer-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:react": "vite",
    "build:react": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "electron . --no-sandbox",
    "dev": "concurrently \"npm:dev:react\" \"wait-on http://localhost:5173 && npm run start\"",
    "build:electron": "npm run build:react && electron-builder",
    "electron:dev": "concurrently \"npm:dev:react\" \"wait-on http://localhost:5173 && npm run start\"",
    "electron:start": "wait-on http://localhost:5173 && electron . --no-sandbox",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@microsoft/signalr": "^7.0.10",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.13.0",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable": "^3.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.1",
    "wait-on": "^8.0.3"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.aj-cs.trebleplayer",
    "productName": "TreblePlayer",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
